# SID Configuration
# Copy this to .env and edit

# Ollama (local LLM backend — must be running)
OLLAMA_BASE_URL=http://localhost:11434

# Legacy model aliases (prefer config/models.yaml for per-purpose routing)
SID_FAST_MODEL=qwen2.5:3b
SID_DEEP_MODEL=qwen2.5:14b

# Data directory (default: ~/.sid/)
# SID_DATA_DIR=/path/to/custom/directory

# Scheduler times (24-hour format)
SID_MORNING_HOUR=8
SID_EVENING_HOUR=21

# Agent behavior
SID_CHECKIN_INTERVAL_HOURS=4   # Check-in every N hours
SID_CHECKIN_THRESHOLD=1        # Min pending tasks before check-in fires

# Voice
SID_WHISPER_MODEL=base.en      # Options: tiny.en, base.en, small.en
SID_SAMPLE_RATE=16000
SID_MAX_RECORDING_SECONDS=60
SID_VAD_THRESHOLD=0.5

# API
SID_API_PORT=8765
SID_API_HOST=127.0.0.1

# Cloud LLM providers (optional — disabled by default in config/models.yaml)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
