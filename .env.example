# SID — Environment Configuration
# Copy to .env and fill in your values.
# Only uncomment/override what you need — everything has a sane default.

# ─────────────────────────────────────────────────────────────────────────────
# Ollama (local LLM backend — must be running before starting SID)
# ─────────────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ─────────────────────────────────────────────────────────────────────────────
# Cloud API keys (optional — only activate if you flip enabled: true
# on "openai" or "anthropic" provider in config/models.yaml)
# ─────────────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────────────────────────────────────
# Data directory — all SQLite + LanceDB files live here (portable)
# ─────────────────────────────────────────────────────────────────────────────
# SID_DATA_DIR=~/.sid

# ─────────────────────────────────────────────────────────────────────────────
# Scheduler (24h clock)
# Development tip: set SID_MORNING_HOUR=99 to stop morning brief from firing
# ─────────────────────────────────────────────────────────────────────────────
SID_MORNING_HOUR=8
SID_EVENING_HOUR=21

# ─────────────────────────────────────────────────────────────────────────────
# Agent behaviour
# ─────────────────────────────────────────────────────────────────────────────
SID_CHECKIN_THRESHOLD=3           # min new thoughts before check-in fires
SID_CHECKIN_INTERVAL_HOURS=1      # how often the check-in job polls

# ─────────────────────────────────────────────────────────────────────────────
# Voice capture
# ─────────────────────────────────────────────────────────────────────────────
SID_WHISPER_MODEL=base.en         # tiny.en (fastest) / base.en / small.en (best)
SID_SAMPLE_RATE=16000
SID_MAX_RECORDING_SECONDS=60
SID_VAD_THRESHOLD=0.5

# ─────────────────────────────────────────────────────────────────────────────
# API server
# ─────────────────────────────────────────────────────────────────────────────
SID_API_HOST=127.0.0.1
SID_API_PORT=8765
